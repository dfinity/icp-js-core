{
  "extends": ["./tsconfig.build.json", "@tsconfig/node22/tsconfig.json"],
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node10",
    "verbatimModuleSyntax": false,
    "lib": ["ES2023", "DOM"],
    "rootDir": "./src",
    "outDir": "./lib/cjs"
  },
  "include": ["./src/**/*.ts"],
  "exclude": ["./src/**/*.test.ts", "./src/agent/canister-env/*.ts"]
}
